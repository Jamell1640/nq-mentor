      <tr class="hi"><td>#6</td><td>97.9%</td><td>41pts</td><td>12:33</td><td>81%</td><td>+92</td></tr>
      <tr class="hi"><td>#7</td><td>95.2%</td><td>43pts</td><td>13:02</td><td>81%</td><td>+85</td></tr>
      <tr class="hi"><td>#8</td><td>92.6%</td><td>46pts</td><td>13:30</td><td>81%</td><td>+80</td></tr>
