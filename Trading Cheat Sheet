<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NQ Cheat Sheet</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:#0a0a0a;
  --paper:#f7f5f0;
  --card:#ffffff;
  --rule:#e8e4dc;
  --green:#1a6b3a;
  --green-bg:#e8f5ee;
  --red:#b91c1c;
  --red-bg:#fef2f2;
  --amber:#92400e;
  --amber-bg:#fffbeb;
  --blue:#1e40af;
  --blue-bg:#eff6ff;
  --mono:'Space Mono',monospace;
  --sans:'DM Sans',sans-serif;
}

body{
  background:var(--paper);
  color:var(--ink);
  font-family:var(--sans);
  padding:24px;
  max-width:960px;
  margin:0 auto;
  font-size:12px;
  line-height:1.4;
}

/* HEADER */
.hdr{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  border-bottom:2px solid var(--ink);
  padding-bottom:10px;
  margin-bottom:16px;
}
.hdr-title{
  font-family:var(--mono);
  font-size:22px;
  font-weight:700;
  letter-spacing:-0.02em;
  line-height:1;
}
.hdr-sub{
  font-size:10px;
  color:#666;
  letter-spacing:0.08em;
  text-transform:uppercase;
  margin-top:3px;
}
.hdr-right{
  font-family:var(--mono);
  font-size:10px;
  color:#888;
  text-align:right;
}

/* GRID LAYOUT */
.grid{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:10px;
  margin-bottom:10px;
}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-bottom:10px}

/* SECTION */
.sec{
  background:var(--card);
  border:1px solid var(--rule);
  border-radius:6px;
  padding:10px 12px;
}
.sec-title{
  font-family:var(--mono);
  font-size:9px;
  font-weight:700;
  letter-spacing:0.12em;
  text-transform:uppercase;
  color:#888;
  border-bottom:1px solid var(--rule);
  padding-bottom:6px;
  margin-bottom:8px;
}
.sec.green{border-left:3px solid var(--green);background:var(--green-bg)}
.sec.red{border-left:3px solid var(--red);background:var(--red-bg)}
.sec.amber{border-left:3px solid #d97706;background:var(--amber-bg)}
.sec.blue{border-left:3px solid var(--blue);background:var(--blue-bg)}
.sec.dark{background:#0a0a0a;border-color:#0a0a0a;color:#fff}
.sec.dark .sec-title{color:#666;border-color:#222}

/* ROW */
.row{
  display:flex;
  justify-content:space-between;
  align-items:baseline;
  padding:3px 0;
  border-bottom:1px solid rgba(0,0,0,0.05);
  gap:8px;
}
.row:last-child{border:none;padding-bottom:0}
.rl{font-size:11px;color:#555;flex:1}
.rv{font-family:var(--mono);font-size:11px;font-weight:700;color:var(--ink);white-space:nowrap}
.rv.g{color:var(--green)}.rv.r{color:var(--red)}.rv.a{color:#d97706}.rv.b{color:var(--blue)}

/* TIER TABLE */
.tier-table{width:100%;border-collapse:collapse;font-size:10px}
.tier-table th{
  font-family:var(--mono);font-size:8px;font-weight:700;
  letter-spacing:0.08em;text-transform:uppercase;color:#888;
  padding:4px 6px;border-bottom:1px solid var(--rule);
  text-align:left;
}
.tier-table td{padding:5px 6px;border-bottom:1px solid rgba(0,0,0,0.04);vertical-align:middle}
.tier-table tr:last-child td{border:none}
.t-num{font-family:var(--mono);font-weight:700;font-size:11px}
.t-bull{color:var(--green)}.t-bear{color:var(--red)}.t-half{color:#d97706}
.badge{
  display:inline-block;padding:1px 6px;border-radius:3px;
  font-family:var(--mono);font-size:8px;font-weight:700;
}
.b-full-bull{background:var(--green-bg);color:var(--green)}
.b-full-bear{background:var(--red-bg);color:var(--red)}
.b-half{background:var(--amber-bg);color:#d97706}

/* PULLBACK TABLE */
.pb-table{width:100%;border-collapse:collapse;font-size:10px}
.pb-table th{font-family:var(--mono);font-size:8px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#888;padding:3px 5px;border-bottom:1px solid var(--rule);text-align:right}
.pb-table th:first-child{text-align:left}
.pb-table td{padding:3px 5px;border-bottom:1px solid rgba(0,0,0,0.04);font-family:var(--mono);font-size:10px;text-align:right}
.pb-table td:first-child{text-align:left;font-weight:700}
.pb-table tr:last-child td{border:none}
.hi{background:rgba(26,107,58,0.08)}
.lo{background:rgba(185,28,28,0.06)}

/* RULE LIST */
.rule{
  display:flex;gap:8px;padding:4px 0;
  border-bottom:1px solid rgba(0,0,0,0.05);
  font-size:11px;align-items:flex-start;
}
.rule:last-child{border:none}
.rule-num{
  font-family:var(--mono);font-weight:700;font-size:9px;
  min-width:18px;color:#aaa;margin-top:1px;
}
.rule-txt{color:#333;line-height:1.5;flex:1}
.rule-txt strong{color:var(--ink);font-weight:600}

/* STAT BLOCK */
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.stat{text-align:center;padding:6px 4px}
.stat-val{font-family:var(--mono);font-size:18px;font-weight:700;line-height:1}
.stat-lbl{font-size:9px;color:#888;text-transform:uppercase;letter-spacing:0.06em;margin-top:2px}

/* WARNING BOX */
.warn{
  background:#0a0a0a;color:#fff;border-radius:6px;
  padding:8px 12px;margin-bottom:10px;
  display:flex;gap:12px;align-items:center;
}
.warn-icon{font-size:18px;flex-shrink:0}
.warn-txt{font-size:11px;line-height:1.6;color:#ccc}
.warn-txt strong{color:#fff}

/* PILL */
.pill{
  display:inline-block;padding:1px 7px;border-radius:20px;
  font-size:9px;font-weight:700;font-family:var(--mono);
  letter-spacing:0.04em;
}
.pill-g{background:var(--green-bg);color:var(--green);border:1px solid #a7d7b8}
.pill-r{background:var(--red-bg);color:var(--red);border:1px solid #f5b8b4}
.pill-a{background:var(--amber-bg);color:#d97706;border:1px solid #fcd98a}

/* FOOTER */
.footer{
  border-top:1px solid var(--rule);
  padding-top:8px;
  display:flex;
  justify-content:space-between;
  font-size:9px;
  color:#aaa;
  font-family:var(--mono);
}
</style>
</head>
<body>

<!-- HEADER -->
<div class="hdr">
  <div>
    <div class="hdr-title">NQ / MNQ — TRADING CHEAT SHEET</div>
    <div class="hdr-sub">8-Tier Model &nbsp;·&nbsp; 5yr backtest 2021–2026 &nbsp;·&nbsp; 1,288 days</div>
  </div>
  <div class="hdr-right">
    ~222 trades/yr<br>
    82.5% model accuracy
  </div>
</div>

<!-- WARNING -->
<div class="warn">
  <div class="warn-icon">⛔</div>
  <div class="warn-txt">
    <strong>SEPTEMBER = NO TRADE (all tiers)</strong> &nbsp;·&nbsp;
    <strong>JUNE = T3/T4 OFF</strong> &nbsp;·&nbsp;
    <strong>After 3:00 PM = continuation drops to 54% — stop entering</strong> &nbsp;·&nbsp;
    No signal = close platform
  </div>
</div>

<!-- ROW 1: TIERS + MORNING FLOW -->
<div class="grid2">

  <!-- TIER TABLE -->
  <div class="sec">
    <div class="sec-title">8-Tier Model — Check Times &amp; Rules</div>
    <table class="tier-table">
      <tr>
        <th>#</th><th>Name</th><th>Check</th><th>Rule</th><th>WR</th><th>Size</th><th>Gate</th>
      </tr>
      <tr>
        <td class="t-num t-bull">T1</td>
        <td><strong>Full Bull</strong></td>
        <td>11am</td>
        <td>KZ swept PDH+closed above · KZ above Lon Hi</td>
        <td class="rv g">90.2%</td>
        <td><span class="badge b-full-bull">FULL</span></td>
        <td>not Sep</td>
      </tr>
      <tr>
        <td class="t-num t-bear">T2</td>
        <td><strong>Full Bear</strong></td>
        <td>11am</td>
        <td>KZ swept PDL+closed below · KZ below Lon Lo</td>
        <td class="rv r">87.3%</td>
        <td><span class="badge b-full-bear">FULL</span></td>
